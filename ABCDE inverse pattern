import java.util.*;
public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        int n = sc.nextInt();
        for (int i = 0; i < n; i++) {
            int c = 69;
            for (int j = n; j > i; j--) {
                   System.out.print((char)c+" ");
                   c--;
            }
            System.out.println();
        }
    }   
}
